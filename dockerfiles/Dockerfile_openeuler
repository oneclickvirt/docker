FROM openeuler/openeuler:22.03
ENV DEBIAN_FRONTEND=noninteractive
ENV ROOT_PASSWORD=oneclick136

RUN dnf -y update && \
    dnf install -y --skip-broken \
        openssh-server \
        curl \
        wget \
        cronie \
        lsof \
        vim \
        nano \
        net-tools \
        procps-ng && \
    dnf clean all

RUN mkdir -p /var/run/sshd && \
    ssh-keygen -A 2>/dev/null || true

RUN sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config && \
    sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config && \
    sed -i 's/^UsePAM yes/UsePAM no/' /etc/ssh/sshd_config

RUN echo 'Related repo https://github.com/oneclickvirt/docker' >> /etc/motd && \
    echo '--by https://t.me/spiritlhl' >> /etc/motd

# CVE-2026-31431 (copy-fail) 缓解：禁止加载 algif_aead 模块
RUN mkdir -p /etc/modprobe.d && \
    echo "install algif_aead /bin/false" > /etc/modprobe.d/disable-algif-aead.conf

COPY scripts/ssh_bash.sh /ssh_bash.sh
RUN chmod +x /ssh_bash.sh

COPY dockerfiles/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 22
CMD ["/entrypoint.sh"]
