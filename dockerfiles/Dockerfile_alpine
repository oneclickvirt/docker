FROM alpine:latest
ENV ROOT_PASSWORD=oneclick136

RUN apk update && \
    apk add --no-cache \
        openssh \
        openssh-server \
        curl \
        wget \
        bash \
        vim \
        htop \
        procps \
        dcron \
        shadow

RUN ssh-keygen -A && \
    mkdir -p /var/run/sshd

RUN sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config && \
    sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config && \
    sed -i 's/^#\?ListenAddress 0.0.0.0/ListenAddress 0.0.0.0/' /etc/ssh/sshd_config

RUN echo 'Related repo https://github.com/oneclickvirt/docker' >> /etc/motd && \
    echo '--by https://t.me/spiritlhl' >> /etc/motd

# CVE-2026-31431 (copy-fail) 缓解：禁止加载 algif_aead 模块
RUN mkdir -p /etc/modprobe.d && \
    echo "install algif_aead /bin/false" > /etc/modprobe.d/disable-algif-aead.conf

COPY scripts/ssh_sh.sh /ssh_sh.sh
RUN chmod +x /ssh_sh.sh

COPY dockerfiles/entrypoint_alpine.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 22
CMD ["/entrypoint.sh"]
