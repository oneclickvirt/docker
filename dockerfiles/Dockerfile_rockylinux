FROM rockylinux/rockylinux:9
ENV DEBIAN_FRONTEND=noninteractive
ENV ROOT_PASSWORD=oneclick136

RUN dnf -y update && \
    dnf install -y --skip-broken \
        openssh-server \
        curl \
        wget \
        cronie \
        lsof \
        vim \
        nano \
        net-tools \
        procps-ng && \
    dnf clean all

RUN mkdir -p /var/run/sshd && \
    ssh-keygen -A 2>/dev/null || true

RUN sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config && \
    sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config && \
    sed -i 's/^UsePAM yes/UsePAM no/' /etc/ssh/sshd_config

RUN echo 'Related repo https://github.com/oneclickvirt/docker' >> /etc/motd && \
    echo '--by https://t.me/spiritlhl' >> /etc/motd

RUN curl -sLo /ssh_bash.sh \
    https://raw.githubusercontent.com/oneclickvirt/docker/refs/heads/main/scripts/ssh_bash.sh && \
    chmod +x /ssh_bash.sh

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 22
CMD ["/entrypoint.sh"]
